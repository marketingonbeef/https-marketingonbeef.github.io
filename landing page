    ];
    var formEl = null;
    for (var i = 0; i < selectors.length; i++) {
      var el = document.querySelector(selectors[i]);
      if (el && !container.contains(el)) { formEl = el; break; }
    }
    if (formEl) {
      moved = true;
      // Remove posicionamento fixo/flutuante
      formEl.style.setProperty('position', 'static', 'important');
      formEl.style.setProperty('bottom', 'auto', 'important');
