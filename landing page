(function () {
  var container = document.getElementById('kommo-form-container');
  if (!container) return;
  var moved = false;
  var attempt = 0;
  function tryMove() {
    if (moved) return;
    attempt++;
    // Tenta encontrar o wrapper do form Kommo injetado no body
    var selectors = [
      '.amoforms-wrapper',
      '[id*="amoforms_wrapper"]',
      '[class*="amoforms-wrap"]',
      '.amoform',
